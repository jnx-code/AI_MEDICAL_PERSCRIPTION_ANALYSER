# Copy this file to .env and fill in your values
# Database: use "sqlite" (no setup needed) or "mysql"
DB_TYPE=sqlite
SQLITE_PATH=medical_prescription.db

# MySQL settings (only needed when DB_TYPE=mysql)
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_password_here
DB_NAME=medical_prescription

# Clinic identity
DOCTOR_NAME=Dr. Smith
HOSPITAL_NAME=City Medical Center
